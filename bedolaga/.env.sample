# Curated subset of what we actually override on top of Bedolaga's own
# .env.example (which ships in the upstream clone at /opt/bedolaga/.env.example -
# ~1150 lines, mostly optional subsystems we don't use). This file is NOT a
# drop-in .env - start from the upstream .env.example and layer these on top.

# ===== Telegram =====
BOT_TOKEN=
ADMIN_IDS=

# ===== Remnawave API =====
REMNAWAVE_API_URL=https://inix-vpn.com
REMNAWAVE_API_KEY=
REMNAWAVE_AUTH_TYPE=api_key

# UUID of the internal squad new users get assigned to (our "production" squad)
SIMPLE_SUBSCRIPTION_SQUAD_UUID=

# ===== Payments =====
# Telegram Stars is the only provider enabled - native to the Bot API, no
# external merchant account needed. Every other provider (YooKassa, CryptoBot,
# Freekassa, etc.) is a real, working integration in Bedolaga, just not
# configured here yet (we don't have accounts with any of them).
TELEGRAM_STARS_ENABLED=true

# ===== Postgres (own dedicated DB, isolated from the Remnawave Panel's) =====
POSTGRES_DB=remnawave_bot
POSTGRES_USER=remnawave_bot_user
POSTGRES_PASSWORD=

# ===== Maintenance mode (currently ON - admin-only access while testing) =====
# Blocks everyone except ADMIN_IDS (and support moderators) with
# MAINTENANCE_MESSAGE instead of letting them use the bot at all - so
# strangers can't stumble onto the bot while it's still being tested.
# Turn off (MAINTENANCE_MODE=false) once ready for real users.
MAINTENANCE_MODE=true
MAINTENANCE_MESSAGE=The bot is currently being set up and tested. Please check back later.
#
# Gotcha #1: `docker compose restart` does NOT re-read .env - Compose only
# resolves env_file at container *creation*. A .env change needs
# `docker compose up -d --force-recreate bot` (plain `up -d` also works if
# the compose file itself changed) to actually take effect.
#
# Gotcha #2: flipping MAINTENANCE_MODE true->restart alone isn't reliable -
# there's a startup race in Bedolaga's own maintenance_service.py between
# the env-driven enable task (from set_bot()) and the Redis-cached-status
# load (from start_monitoring()); depending on which wins, the cached
# (previously "off") state can clobber the freshly-enabled one back to off.
# Symptom: env shows MAINTENANCE_MODE=true and logs claim maintenance is on,
# but `docker exec remnawave_bot_redis redis-cli GET maintenance_status`
# shows `"is_active": false`. Fix: write the correct state directly into
# that Redis key (matching the JSON shape maintenance_service.py expects,
# with "auto_enabled": false so the API-recovery monitor won't auto-disable
# it) before/instead of relying on the env flag alone, then recreate the
# bot container so it loads that state on boot.

# ===== Disabled to avoid startup crashes / errors =====
# Fails on boot with a placeholder chat ID from the example file if left on,
# and we haven't set up an admin notifications channel.
ADMIN_NOTIFICATIONS_ENABLED=false

# The upstream .env.example ships these as int-typed fields but with
# non-numeric placeholder/comment text as their "empty" value, which crashes
# pydantic-settings validation at startup. Comment them out (not just blank)
# unless/until the corresponding provider is actually configured:
#   ADMIN_REPORTS_TOPIC_ID
#   MULENPAY_SHOP_ID
#   FREEKASSA_SHOP_ID
#   FREEKASSA_PAYMENT_SYSTEM_ID
#   KASSA_AI_SHOP_ID
#   SEVERPAY_MID
#   APPLE_IAP_APP_APPLE_ID
#   LOG_ROTATION_TOPIC_ID
